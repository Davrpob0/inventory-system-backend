generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum MovementType {
  ENTRY
  EXIT
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  warehouseOperator  WarehouseOperator?
  inventoryMovements InventoryMovement[]

  @@map("users")
}

model Warehouse {
  id               String   @id @default(uuid()) @db.Uuid
  name             String
  location         String
  maxCapacityUnits Int      @map("max_capacity_units")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  operators          WarehouseOperator[]
  inventoryMovements InventoryMovement[]

  @@map("warehouses")
}

model Product {
  id            String   @id @default(uuid()) @db.Uuid
  sku           String   @unique
  name          String
  description   String?
  unitOfMeasure String   @map("unit_of_measure")
  minStockAlert Int      @map("min_stock_alert")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  inventoryMovements InventoryMovement[]

  @@map("products")
}

model WarehouseOperator {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  assignedAt  DateTime @default(now()) @map("assigned_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)

  @@index([warehouseId])
  @@map("warehouse_operators")
}

model InventoryMovement {
  id          String       @id @default(uuid()) @db.Uuid
  productId   String       @map("product_id") @db.Uuid
  warehouseId String       @map("warehouse_id") @db.Uuid
  userId      String       @map("user_id") @db.Uuid
  type        MovementType
  quantity    Int
  reference   String?
  notes       String?
  createdAt   DateTime     @default(now()) @map("created_at")

  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([warehouseId])
  @@index([userId])
  @@index([warehouseId, productId, createdAt])
  @@map("inventory_movements")
}
